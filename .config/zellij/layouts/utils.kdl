layout {
  pane size=1 borderless=true {
    plugin location="tab-bar"
  }
  pane stacked=true {
    pane expanded=true cwd="~/second-brain/" command="nvim"
    pane cwd="~" command="btop" start_suspended=true
    pane cwd="~"
  }
  pane size=1 borderless=true {
    plugin location="status-bar"
  }
}
