{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--headless"
      ],
      "enabled": true
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": true,
      "oauth": {
        "clientId": "{env:FIGMA_OAUTH_CLIENT_ID}",
        "clientSecret": "{env:FIGMA_OAUTH_CLIENT_SECRET}"
      }
    },
    "datadog": {
      "type": "remote",
      "url": "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp",
      "enabled": true
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_CLASSIC_PAT}",
        "X-MCP-Toolsets": "default,actions"
      },
      "enabled": true
    },
    "homebrew": {
      "type": "local",
      "command": [
        "brew",
        "mcp-server"
      ],
      "enabled": true
    }
  }
}
